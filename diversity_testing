#alpha diversity 

#shannon - linear mixed effects model & kruskal 
shannon <- estimate_richness(PS1, measures = "Shannon")
metadata <- data.frame(sample_data(PS1))
shannon_data <- cbind(metadata, shannon)
shannon_data$Volume <- factor(shannon_data$Volume)
shannon_data$Group <- factor(shannon_data$Group)

lmm_shannon <- lmer(Shannon ~ Volume * Group + (1 | Batch), data = shannon_data)
summary(lmm_shannon)
Anova(lmm_shannon, type = 3)
kruskal.test(Shannon ~ Batch, data = shannon_data)

#inverse simpson - linear mixed effects model & kruskal 
invsimp <- estimate_richness(PS1, measures = "InvSimpson")
simp_data <- cbind(metadata, invsimp)
simp_data$Volume <- factor(simp_data$Volume)
simp_data$Group <- factor(simp_data$Group)

lmm_simp <- lmer(InvSimpson ~ Volume * Group + (1 | Batch), data = simp_data)
summary(lmm_simp)
Anova(lmm_simp, type = 3)
kruskal.test(InvSimpson ~ Batch, data = simp_data)

#observed richness - linear mixed effects model & kruskal 
taxa.obs <- rowSums(otu_table(PS1) > 0)
rich_data <- cbind(metadata, Richness = taxa.obs)
rich_data$Volume <- factor(rich_data$Volume)
rich_data$Group <- factor(rich_data$Group)

lmm_rich <- lmer(Richness ~ Volume * Group + (1 | Batch), data = rich_data)
summary(lmm_rich)
Anova(lmm_rich, type = 3)
kruskal.test(Richness ~ Batch, data = rich_data)


