run_permdisp_volcat <- function(batch_name, distmat, meta) {
  idx <- meta$Batch == batch_name
  sub_meta <- meta[idx, ]
  sub_dist <- as.dist(as.matrix(distmat)[idx, idx])
  
  #skip if not enough categories
  if (length(unique(sub_meta$VolCat)) < 2) return(NULL)
  
  #run betadisper
  bd <- betadisper(sub_dist, as.factor(sub_meta$VolCat))
  test <- anova(bd)
  
  data.frame(
    Batch = batch_name,
    F_value = test$`F value`[1],
    p_value = test$`Pr(>F)`[1],
    MeanDist_Low = mean(bd$distances[sub_meta$VolCat == "Low"], na.rm = TRUE),
    MeanDist_High = mean(bd$distances[sub_meta$VolCat == "High"], na.rm = TRUE)
  )
}

disp_results_volcat <- lapply(unique(Meta2$Batch), run_permdisp_volcat, distmat = taxa.diss, meta = Meta2)
