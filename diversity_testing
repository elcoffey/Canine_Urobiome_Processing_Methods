#dispersion testing

run_permdisp <- function(batch_name, distmat, meta) {
  idx <- meta$Batch == batch_name
  sub_meta <- meta[idx, ]
  
  #subset distance matrix for this batch
  sub_dist <- as.dist(as.matrix(distmat)[idx, idx])
  
  #skip if batch has < 2 groups or < 3 samples total
  if (length(unique(sub_meta$Group)) < 2) return(NULL)
  
  #run betadisper on Group
  bd <- betadisper(sub_dist, sub_meta$Group)
  test <- anova(bd)
  
  #store results
  data.frame(
    Batch = batch_name,
    F_value = test$`F value`[1],
    p_value = test$`Pr(>F)`[1],
    MeanDist_Pellet = mean(bd$distances[sub_meta$Group == "Pellet"], na.rm = TRUE),
    MeanDist_Filter = mean(bd$distances[sub_meta$Group == "Filter"], na.rm = TRUE)
  )
}

#apply to all batches
disp_results <- lapply(unique(Meta2$Batch), run_permdisp, distmat = taxa.diss, meta = Meta2)
disp_results <- do.call(rbind, disp_results)
