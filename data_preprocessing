##export for filtering and decontam

# load libraries
library(phyloseq); packageVersion("phyloseq")
library(ggplot2); packageVersion("ggplot2")
library(decontam); packageVersion("decontam")
library(labdsv); packageVersion("labdsv")

# load data (mitochondria, chloroplasts, chimeras, PC contams removed)
ASV_raw <- read.csv("UMGC_16s_raw.csv", header = TRUE, row.names = 1)
Meta <- read.csv("Metadata_UMGC_v3.csv", header = TRUE, row.names = 1)

#remove ASVs with 10 or less reads across dataset AND present in < 2 samples
ASV.sums <- colSums(ASV_raw)
ASV_filtered <- ASV_raw[,which(ASV.sums >10)]      
ASV_filtered <- dropspc(ASV_filtered, 2)    

#ensure matching samples between metadata and ASV table
ASV_filtered <- ASV_filtered[order(rownames(ASV_filtered)), ]
Meta <- Meta[order(rownames(Meta)), ]
stopifnot(identical(rownames(Meta), rownames(ASV_filtered)))

#create phyloseq object
ps <- phyloseq(
  otu_table(ASV_filtered, taxa_are_rows = FALSE),
  sample_data(Meta)
)

#inspect library size
df <- as.data.frame(sample_data(ps))
df$LibrarySize <- sample_sums(ps)
df <- df[order(df$LibrarySize), ]
df$index <- seq_len(nrow(df))
ggplot(df, aes(x = index, y = LibrarySize, color = SampleType)) +
  geom_point() +
  theme_classic()

#identify contaminants using prevalence method
sample_data(ps)$is.neg <- sample_data(ps)$SampleType == "Control"
contam_prev <- isContaminant(ps, method = "prevalence", neg = "is.neg", threshold = 0.5)

#summary of contaminants
table(contam_prev$contaminant)
hist(contam_prev$p, 50)

#remove contaminants
ps_clean <- prune_taxa(!contam_prev$contaminant, ps)

#export contaminant info and cleaned ASV table
write.csv(contam_prev, "Filtered_contam_prev0.5.csv")
write.csv(as.data.frame(otu_table(ps_clean)), "UMGC_PostDecontam.csv")

